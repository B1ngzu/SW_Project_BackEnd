@startuml Auth - Login
header Authentication Sequence Diagram
footer Page %page% of %lastpage%
title "Auth - Login (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:auth" as routerAuth
participant "<<controllers>>\n:auth" as controllersAuth
participant "<<model>>\n:User" as modelUser
database "<<MongoDB>>\n:User" as UserDatabase

client -> server ++: req.post('/api/v1/auth/login')
server -> routerAuth ++: app.use('/api/v1/auth', auth)
routerAuth -> controllersAuth ++: login()

alt email or password missing
    controllersAuth -> client: 400 { success: false }
end

controllersAuth -> modelUser ++: findOne({ email }).select('+password')
modelUser -> UserDatabase ++: UserSchema
UserDatabase --> modelUser --: user
controllersAuth <-- modelUser --: user

alt user not found
    controllersAuth -> client: 400 Invalid credentials
end

controllersAuth -> modelUser: matchPassword(password)
note right of modelUser: bcrypt.compare()

alt password not match
    controllersAuth -> client: 401 Invalid credentials
end

controllersAuth -> controllersAuth --: sendTokenResponse()\ngetSignedJwtToken()
controllersAuth -> client --: res.cookie(token) + { success, token }

@enduml

