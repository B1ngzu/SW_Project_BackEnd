@startuml Reservation - Cancel
header Reservation Sequence Diagram
footer Page %page% of %lastpage%
title "Reservation - Cancel (PUT)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:reservations" as routerRes
participant "<<middleware>>\n:protect" as middlewareProtect
participant "<<controllers>>\n:reservations" as controllersRes
participant "<<model>>\n:Reservation" as modelRes
database "<<MongoDB>>\n:Reservation" as ResDatabase

client -> server ++: req.put('/api/v1/reservations/:id/cancel')\nAuthorization: Bearer <token>
server -> routerRes ++: app.use('/api/v1/reservations', reservations)
routerRes -> middlewareProtect ++: protect()

alt token missing or invalid
    middlewareProtect -> client: 401 Not authorized
end

middlewareProtect -> routerRes --: next()
routerRes -> controllersRes ++: cancelReservation()
controllersRes -> modelRes ++: findById(req.params.id)
modelRes -> ResDatabase ++: ReservationSchema
ResDatabase --> modelRes --: reservation
controllersRes <-- modelRes --: reservation

alt reservation not found
    controllersRes -> client: 404 Reservation not found
end

alt user != owner && role != 'admin'
    controllersRes -> client: 401 Not authorized
end

alt status == 'cancelled'
    controllersRes -> client: 400 Already cancelled
end

controllersRes -> modelRes ++: reservation.status = 'cancelled'\nsave()
modelRes -> ResDatabase ++: ReservationSchema
ResDatabase --> modelRes --: reservation
controllersRes <-- modelRes --: reservation
controllersRes -> client --: 200 { success, data: reservation }

@enduml
