@startuml Reservation - Add
header Reservation Sequence Diagram
footer Page %page% of %lastpage%
title "Reservation - Add (POST)"

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:reservations" as routerRes
participant "<<middleware>>\n:protect" as middlewareProtect
participant "<<controllers>>\n:reservations" as controllersRes
participant "<<model>>\n:CoWork" as modelCoWork
participant "<<model>>\n:Reservation" as modelRes
database "<<MongoDB>>\n:CoWork" as CoWorkDatabase
database "<<MongoDB>>\n:Reservation" as ResDatabase

client -> server ++: req.post('/api/v1/coworks/:coworkId/reservations')\nAuthorization: Bearer <token>
server -> routerRes ++: app.use('/api/v1/coworks/:coworkId/reservations')
routerRes -> middlewareProtect ++: protect()

alt token missing or invalid
    middlewareProtect -> client: 401 Not authorized
end

middlewareProtect -> routerRes --: next()
routerRes -> controllersRes ++: addReservation()

controllersRes -> modelCoWork ++: findById(coworkId)
modelCoWork -> CoWorkDatabase ++: CoWorkSchema
CoWorkDatabase --> modelCoWork --: cowork
controllersRes <-- modelCoWork --: cowork

alt cowork not found
    controllersRes -> client: 404 No cowork found
end

controllersRes -> modelRes ++: find({ user: req.user.id, status: 'active' })
modelRes -> ResDatabase ++: ReservationSchema
ResDatabase --> modelRes --: existedReservations
controllersRes <-- modelRes --: existedReservations

alt existedReservations >= 3 && role != 'admin'
    controllersRes -> client: 400 Already made 3 reservations
end

controllersRes -> modelRes ++: create(req.body)
modelRes -> ResDatabase ++: ReservationSchema
ResDatabase --> modelRes --: reservation
controllersRes <-- modelRes --: reservation
controllersRes -> client --: 200 { success, data: reservation }

@enduml

